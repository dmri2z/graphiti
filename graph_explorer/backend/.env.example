# Which graph database the explorer reads from. Options: falkordb (default), neo4j.
# Point this at the SAME database your mcp_server / ingestion writes to.
GRAPH_DB_PROVIDER=falkordb

# --- FalkorDB (default) ---
FALKORDB_URI=redis://localhost:6379
FALKORDB_PASSWORD=
FALKORDB_DATABASE=default_db

# --- Neo4j (only used when GRAPH_DB_PROVIDER=neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Default group_id shown first in the UI dropdown.
GRAPHITI_GROUP_ID=default_db

# --- Optional: server-side semantic search ---
# If set, the /api/search endpoint runs Graphiti hybrid search (embeddings + BM25).
# If unset, /api/search returns 503 and the frontend falls back to client-side text search.
OPENAI_API_KEY=
EMBEDDER_MODEL=text-embedding-3-small

# CORS origin of the frontend dev server.
FRONTEND_ORIGIN=http://localhost:5173
